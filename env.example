# Шаблон окружения для docker-compose. Скопируйте в .env и заполните:  cp env.example .env
# Реальный .env НЕ коммитить (он в .gitignore). Секреты в образ не зашиваются.

# --- Секреты (инъекция в рантайме) ---
# Master key для расшифровки db_conf/secrets (то, что раньше вводилось через pwinput).
UH2S_MASTER_KEY=
# Зашифрованный объект конфигурации БД (генерируется вспомогательным модулем).
# Для sqlite укажите внутри db_path = /data/app.db (том uh2s-data).
UH2S_DB_CONF=
# Зашифрованный ключ хранилища сессий nicegui (storage secret).
UH2S_STORAGE_KEY=

# --- Порты на хосте ---
UH2S_PORT=8082
UH2S_MCP_PORT=8090

# --- Планировщик расписаний (cron) ---
# Работает в web-сервисе (не в mcp). on|off. Держите один web-инстанс (иначе двойные срабатывания).
UH2S_SCHEDULER=on

# --- Скачивание результатов SAVE ---
# Каталог для temp-файлов экспорта (по умолчанию системный tempdir). В контейнере укажите том.
UH2S_EXPORT_DIR=
# Порог inline-скачивания (МБ). Файлы <= порога отдаются blob'ом через websocket — работает и при
# самоподписанном TLS. Больше порога — потоковый роут /download (мимо websocket, но браузер требует
# ДОВЕРЕННЫЙ TLS-сертификат, иначе скачивание рвётся с «проверьте подключение»). Деф. 50.
# То же можно задать аргументом front.py: --download_inline_max_mb.
UH2S_DOWNLOAD_INLINE_MAX_MB=50

# --- Версия для логов (обычно вывод git describe --tags --abbrev=0) ---
APP_VERSION=0.0.0-docker
